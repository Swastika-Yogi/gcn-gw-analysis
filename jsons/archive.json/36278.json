{
  "subject": "LIGO/Virgo S240422ed: Swift-XRT detection of 3 possible counterparts",
  "eventId": "LIGO/Virgo S240422ed",
  "submittedHow": "email",
  "bibcode": "2024GCN.36278....1E",
